{
  "GAS_LOGGER_PARENT_FOLDER_ID": "<Drive folder ID or URL of the shared log root>",
  "GAS_LOGGER_PROJECT_PREFIX": "F3Go30",
  "GAS_LOGGER_LOCAL_PATH": "<local filesystem path to mounted Drive folder, e.g. /mnt/g/My Drive/GAS-Logger>",
  "templateScriptId":      "<template script project ID — Apps Script editor > Project Settings > IDs>",
  "templateSpreadsheetId": "<template spreadsheet ID — from spreadsheet URL /d/<ID>/>",
  "monthScriptId":         "<current month tracker script project ID>",
  "monthSpreadsheetId":    "<current month tracker spreadsheet ID>",
  "testScriptId":          "<test tracker script project ID>",
  "testSpreadsheetId":     "<test tracker spreadsheet ID>",
  "axiomDataset":          "<Axiom dataset name, e.g. go30-tracker — optional, used by query-axiom.py and GasLogger.flush()>",
  "axiomToken":            "<Axiom ingest token — also set as the GAS script property AXIOM_TOKEN on the Template>",
  "axiomQueryToken":       "<Axiom query token — used only by query-axiom.py; may be the same token as axiomToken>"
}
